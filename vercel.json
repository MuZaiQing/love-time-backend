{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/index.js"
    }
  ],
  "functions": {
    "server/index.js": {
      "runtime": "@vercel/node@3.2.13",
      "memory": 256,
      "maxDuration": 10
    }
  }
}
